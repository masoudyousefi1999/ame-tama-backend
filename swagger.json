  "info": {
    "title": "API",
    "description": "### REST\n\nRoutes follow Richardson level 3.\n\n<details><summary>Detailed spec</summary>\n<p>\n\n…(your route descriptions)…\n\n</p>\n</details>",
    "version": "v1.0.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "UserRegisterDto": {
        "type": "object",
        "properties": {
          "password": {
            "type": "string",
            "minLength": 6
          },
          "phone": {
            "type": "string"
          },
          "otp": {
            "type": "string"
          },
          "email": {
            "type": "string"
          }
        }
      },
      "RoleType": {
        "type": "string",
        "enum": [
          "USER",
          "ADMIN"
        ]
      },
      "UserDto": {
        "type": "object",
        "properties": {
          "uuid": {
            "type": "string",
            "format": "uuid"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string"
          },
          "firstName": {
            "type": "string",
            "nullable": true
          },
          "lastName": {
            "type": "string",
            "nullable": true
          },
          "username": {
            "type": "string",
            "nullable": true
          },
          "role": {
            "allOf": [
              {
                "$ref": "#/components/schemas/RoleType"
              }
            ]
          },
          "email": {
            "type": "string",
            "toLowerCase": true,
            "nullable": true
          },
          "avatar": {
            "type": "string",
            "nullable": true
          },
          "phone": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "SendOtpDto": {
        "type": "object",
        "properties": {
          "phone": {
            "type": "string",
            "description": "phone number for sending otp"
          }
        },
        "required": [
          "phone"
        ]
      },
